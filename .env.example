# Public — safe to expose in browser. Used by the anon Supabase client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — bypasses RLS. Never expose to the browser.
# Used by scripts (seed, reset) and by server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection — used by scripts/migrate.ts to apply DDL.
# Use the Session pooler URI from Dashboard → Settings → Database → Connection string.
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# OpenAI — server-only, used for natural-language entity extraction.
OPENAI_API_KEY=sk-proj-...
OPENAI_EXTRACTION_MODEL=gpt-4o
